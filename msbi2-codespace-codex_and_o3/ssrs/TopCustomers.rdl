<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <DataSources>
    <DataSource Name="DW">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source={{SQL_SERVER}};Initial Catalog=DW</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>DataBase</rd:SecurityType>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="TopCustomers">
      <Query>
        <DataSourceName>DW</DataSourceName>
        <CommandText>SELECT TOP 10 CustomerId, CustomerName, RegionName, SalesCount, SalesAmount FROM rpt.vTopCustomers ORDER BY SalesAmount DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="CustomerId">
          <DataField>CustomerId</DataField>
        </Field>
        <Field Name="CustomerName">
          <DataField>CustomerName</DataField>
        </Field>
        <Field Name="RegionName">
          <DataField>RegionName</DataField>
        </Field>
        <Field Name="SalesCount">
          <DataField>SalesCount</DataField>
        </Field>
        <Field Name="SalesAmount">
          <DataField>SalesAmount</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportSections>
    <ReportSection>
      <Body>
        <ReportItems>
          <Textbox Name="Title">
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>Top Customers</Value>
                    <Style>
                      <FontSize>16pt</FontSize>
                      <FontWeight>Bold</FontWeight>
                    </Style>
                  </TextRun>
                </TextRuns>
              </Paragraph>
            </Paragraphs>
            <Top>0.1in</Top>
            <Left>0.1in</Left>
            <Height>0.3in</Height>

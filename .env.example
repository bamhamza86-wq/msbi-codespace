# Minimum requis : rien pour le mode paper. Ajoutez ces deux valeurs pour lire le compte Kraken.
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Le réel reste volontairement verrouillé. Ne jamais accorder la permission de retrait.
GUARDIAN_ENABLE_LIVE=false
# GUARDIAN_LIVE_CONFIRMATION=I_ACCEPT_LIVE_TRADING_RISK

# Garde-fous ajustables (valeurs prudentes par défaut)
GUARDIAN_QUOTE=EUR
GUARDIAN_PAPER_BALANCE=10000
GUARDIAN_SCAN_INTERVAL=300
GUARDIAN_MAX_PAIRS=35
GUARDIAN_MAX_POSITIONS=5
GUARDIAN_RISK_PER_TRADE=0.0075
GUARDIAN_MAX_DAILY_LOSS=0.025
GUARDIAN_STOP_LOSS=0.025
GUARDIAN_TAKE_PROFIT=0.055

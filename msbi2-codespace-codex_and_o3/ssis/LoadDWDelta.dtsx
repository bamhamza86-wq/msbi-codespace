    </DTS:ConnectionManager>
  </DTS:ConnectionManagers>
  <DTS:Variables />
  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\Run DW delta load"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{08DC45A3-315B-4BA4-964A-537AE55E57E0}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:ObjectName="Run DW delta load">
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{E71F0363-9B92-42A8-8D25-2189973F225E}"
          SQLTask:ResultType="ResultSetType_None"
          SQLTask:SqlStatementSource="EXEC etl.usp_LoadDeltaAll @BatchName = N'ssis-delta';"
          SQLTask:SqlStatementSourceType="DirectInput"
          SQLTask:TimeOut="0" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Validate DW delta load"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{A51D7CE4-A2E6-412C-AD5B-12E5A4690787}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:ObjectName="Validate DW delta load">
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{E71F0363-9B92-42A8-8D25-2189973F225E}"
          SQLTask:ResultType="ResultSetType_None"
          SQLTask:SqlStatementSource="DECLARE @FactRows int = (SELECT COUNT(*) FROM dw.FactSales); IF @FactRows &lt; 1 THROW 51001, 'FactSales is empty after SSIS delta load.', 1; SELECT @FactRows AS FactRows;"
          SQLTask:SqlStatementSourceType="DirectInput"
          SQLTask:TimeOut="0" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>

<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <DataSources>
    <DataSource Name="DW"><ConnectionProperties><DataProvider>SQL</DataProvider><ConnectString>Data Source={{SQL_SERVER}};Initial Catalog=DW</ConnectString></ConnectionProperties><rd:SecurityType>DataBase</rd:SecurityType></DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="MonthlySales">
      <Query><DataSourceName>DW</DataSourceName><CommandText>SELECT CalendarYear, MonthNumber, MonthName, SalesCount, SalesAmount FROM rpt.vMonthlySales ORDER BY CalendarYear, MonthNumber</CommandText></Query>
      <Fields>
        <Field Name="CalendarYear"><DataField>CalendarYear</DataField></Field>
        <Field Name="MonthNumber"><DataField>MonthNumber</DataField></Field>
        <Field Name="MonthName"><DataField>MonthName</DataField></Field>
        <Field Name="SalesCount"><DataField>SalesCount</DataField></Field>
        <Field Name="SalesAmount"><DataField>SalesAmount</DataField></Field>
      </Fields>
    </DataSet>
  </DataSets>
  <Body>
    <ReportItems>
      <Textbox Name="Title"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Monthly Sales</Value><Style><FontSize>16pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Top>0.1in</Top><Left>0.1in</Left><Height>0.3in</Height><Width>6in</Width></Textbox>
      <Tablix Name="MonthlySalesTable">
        <TablixBody>
          <TablixColumns><TablixColumn><Width>1.0in</Width></TablixColumn><TablixColumn><Width>1.5in</Width></TablixColumn><TablixColumn><Width>1.2in</Width></TablixColumn><TablixColumn><Width>1.4in</Width></TablixColumn></TablixColumns>
          <TablixRows>
            <TablixRow><Height>0.25in</Height><TablixCells>
              <TablixCell><CellContents><Textbox Name="HYear"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Year</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
              <TablixCell><CellContents><Textbox Name="HMonth"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Month</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
              <TablixCell><CellContents><Textbox Name="HCount"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Sales Count</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
              <TablixCell><CellContents><Textbox Name="HAmount"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Sales Amount</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
            </TablixCells></TablixRow>
            <TablixRow><Height>0.25in</Height><TablixCells>
              <TablixCell><CellContents><Textbox Name="DYear"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!CalendarYear.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
              <TablixCell><CellContents><Textbox Name="DMonth"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!MonthName.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
              <TablixCell><CellContents><Textbox Name="DCount"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!SalesCount.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
              <TablixCell><CellContents><Textbox Name="DAmount"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!SalesAmount.Value</Value><Style><Format>N2</Format></Style></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
            </TablixCells></TablixRow>
          </TablixRows>
        </TablixBody>
        <TablixColumnHierarchy><TablixMembers><TablixMember/><TablixMember/><TablixMember/><TablixMember/></TablixMembers></TablixColumnHierarchy>
        <TablixRowHierarchy><TablixMembers><TablixMember><KeepWithGroup>After</KeepWithGroup></TablixMember><TablixMember><Group Name="MonthlySalesDetails"/></TablixMember></TablixMembers></TablixRowHierarchy>
        <DataSetName>MonthlySales</DataSetName><Top>0.6in</Top><Left>0.1in</Left><Height>0.5in</Height><Width>5.1in</Width>
      </Tablix>
    </ReportItems>
    <Height>1.4in</Height>
  </Body>
  <Width>6.8in</Width>
  <Page><PageHeight>11in</PageHeight><PageWidth>8.5in</PageWidth><LeftMargin>0.5in</LeftMargin><RightMargin>0.5in</RightMargin><TopMargin>0.5in</TopMargin><BottomMargin>0.5in</BottomMargin></Page>
</Report>
